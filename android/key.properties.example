# Copy this file to android/key.properties and fill in your release keystore values.
# Never commit key.properties or your .jks / .keystore file.
#
# Generate a keystore (run once):
#   keytool -genkey -v -keystore upload-keystore.jks -keyalg RSA -keysize 2048 -validity 10000 -alias upload
#
# storeFile path is relative to android/app/

storePassword=your-store-password
keyPassword=your-key-password
keyAlias=upload
storeFile=upload-keystore.jks
